<mujoco model="fr3 reach-avoid">
  <compiler angle="radian" meshdir="mujoco_menagerie/franka_fr3/assets"/>
  <include file="mujoco_menagerie/franka_fr3/fr3.xml"/>

  <statistic center="0.3 0 0.4" extent="1.0"/>

  <option timestep="0.002" integrator="implicitfast"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="150" elevation="-25"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
      rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <material name="obstacle_red" rgba="0.8 0.1 0.1 0.6"/>
    <material name="goal_green" rgba="0.1 0.9 0.1 0.8"/>
  </asset>

  <worldbody>
    <light pos="0 0 2.0" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- Cylindrical obstacle in the workspace -->
    <body name="obstacle" pos="0.45 0.0 0.35">
      <geom name="obstacle_geom" type="cylinder" size="0.06 0.25"
            material="obstacle_red" contype="0" conaffinity="0"
            mass="0"/>
    </body>

    <!-- Goal target (visual only) -->
    <body name="goal_target" pos="0.5 0.3 0.4">
      <geom name="goal_geom" type="sphere" size="0.04"
            material="goal_green" contype="0" conaffinity="0"
            mass="0"/>
    </body>
  </worldbody>
</mujoco>
