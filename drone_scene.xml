<mujoco model="omnivla_drone_room">
  <option gravity="0 0 -9.81" integrator="RK4" density="1.225" viscosity="1.8e-5" timestep="0.002"/>

  <visual>
    <global offwidth="640" offheight="640"/>
    <quality shadowsize="2048"/>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
  </visual>

  <asset>
    <texture name="floor_tex" type="2d" builtin="checker" width="512" height="512"
             rgb1=".85 .78 .65" rgb2=".75 .68 .55"/>
    <material name="floor_mat"  texture="floor_tex" texrepeat="6 6" reflectance="0.1"/>
    <material name="wall_mat"   rgba=".93 .91 .87 1" specular="0.1"/>
    <material name="red_mat"    rgba=".95 .15 .15 1" specular="0.5"/>
    <material name="green_mat"  rgba=".15 .80 .25 1" specular="0.5"/>
    <material name="blue_mat"   rgba=".15 .35 .95 1" specular="0.5"/>
    <material name="pillar_mat" rgba=".9 .2 .2 0.7"/>
    <material name="shelf_mat"  rgba=".75 .70 .60 1"/>

    <!-- Crazyflie primitive-geom materials -->
    <material name="cf_body"  rgba="0.10 0.10 0.10 1" specular="0.30" shininess="0.30"/>
    <material name="cf_pcb"   rgba="0.10 0.30 0.20 1" specular="0.20" shininess="0.25"/>
    <material name="cf_prop"  rgba="0.55 0.60 0.75 1" specular="0.15" shininess="0.15"/>
    <material name="cf_motor" rgba="0.85 0.85 0.85 1" specular="0.40" shininess="0.40"/>
  </asset>

  <worldbody>
    <!-- Lighting -->
    <light pos="0 0 2.8" dir="0 0 -1" diffuse=".55 .55 .52" specular=".15 .15 .15" castshadow="true"/>
    <light pos="-2 2 2.5" dir=".5 -.5 -.7" diffuse=".3 .3 .3" castshadow="false"/>
    <light pos="2 -2 2.5" dir="-.5 .5 -.7" diffuse=".3 .3 .3" castshadow="false"/>

    <!-- Floor + walls + ceiling (room is 6x6x3.1 m) -->
    <geom name="floor"   type="plane" size="3 3 .1" material="floor_mat"/>
    <geom name="wall_N"  type="box"   size="3.2 .1 1.55" pos="0  3.1 1.55" material="wall_mat"/>
    <geom name="wall_S"  type="box"   size="3.2 .1 1.55" pos="0 -3.1 1.55" material="wall_mat"/>
    <geom name="wall_E"  type="box"   size=".1 3.2 1.55" pos=" 3.1 0 1.55" material="wall_mat"/>
    <geom name="wall_W"  type="box"   size=".1 3.2 1.55" pos="-3.1 0 1.55" material="wall_mat"/>
    <geom name="ceiling" type="box"   size="3.2 3.2 .05" pos="0 0 3.05" material="wall_mat" group="3"/>

    <!-- Single translucent cylindrical obstacle, placed between start and goal at runtime. -->
    <body name="obstacle" pos="0.0 0.0 1.5">
      <geom type="sphere" size="0.5" material="pillar_mat" contype="1" conaffinity="1"/>
    </body>

    <!-- Goal markers: colored spheres at fixed heights -->
    <body name="goal_red"   pos="-2.0  2.0 1.50">
      <geom type="sphere" size=".15" material="red_mat"   contype="0" conaffinity="0"/>
    </body>
    <body name="goal_green" pos=" 2.3 -2.3 1.20">
      <geom type="sphere" size=".4" material="green_mat" contype="0" conaffinity="0"/>
    </body>
    <body name="goal_blue"  pos="-2.3 -2.3 1.80">
      <geom type="sphere" size=".15" material="blue_mat"  contype="0" conaffinity="0"/>
    </body>

    <!-- ============================================================
         Crazyflie 2.1 (primitive-geom, inlined for sandbox simplicity).
         Same mass / inertia / actuator layout as MuJoCo Menagerie
         bitcraze_crazyflie_2.
         ============================================================ -->
    <body name="cf2" pos="0 0 0.4">
      <freejoint name="cf2_freejoint"/>
      <inertial pos="0 0 0" mass="0.027"
                diaginertia="2.3951e-5 2.3951e-5 3.2347e-5"/>

      <geom name="cf_pcb"  type="box" pos="0 0 -0.002" size="0.030 0.030 0.003" material="cf_pcb"
            contype="0" conaffinity="0"/>
      <geom name="cf_hull" type="box" pos="0 0  0.006" size="0.018 0.018 0.005" material="cf_body"
            contype="0" conaffinity="0"/>

      <geom name="cf_arm_fr" type="capsule" size="0.0025" fromto="0 0 0  0.033  0.033 0" material="cf_body" contype="0" conaffinity="0"/>
      <geom name="cf_arm_fl" type="capsule" size="0.0025" fromto="0 0 0  0.033 -0.033 0" material="cf_body" contype="0" conaffinity="0"/>
      <geom name="cf_arm_br" type="capsule" size="0.0025" fromto="0 0 0 -0.033  0.033 0" material="cf_body" contype="0" conaffinity="0"/>
      <geom name="cf_arm_bl" type="capsule" size="0.0025" fromto="0 0 0 -0.033 -0.033 0" material="cf_body" contype="0" conaffinity="0"/>

      <geom name="cf_motor_fr" type="cylinder" size="0.004 0.005" pos=" 0.033  0.033 0.004" material="cf_motor" contype="0" conaffinity="0"/>
      <geom name="cf_motor_fl" type="cylinder" size="0.004 0.005" pos=" 0.033 -0.033 0.004" material="cf_motor" contype="0" conaffinity="0"/>
      <geom name="cf_motor_br" type="cylinder" size="0.004 0.005" pos="-0.033  0.033 0.004" material="cf_motor" contype="0" conaffinity="0"/>
      <geom name="cf_motor_bl" type="cylinder" size="0.004 0.005" pos="-0.033 -0.033 0.004" material="cf_motor" contype="0" conaffinity="0"/>
      <geom name="cf_prop_fr" type="cylinder" size="0.023 0.001" pos=" 0.033  0.033 0.010" material="cf_prop" contype="0" conaffinity="0"/>
      <geom name="cf_prop_fl" type="cylinder" size="0.023 0.001" pos=" 0.033 -0.033 0.010" material="cf_prop" contype="0" conaffinity="0"/>
      <geom name="cf_prop_br" type="cylinder" size="0.023 0.001" pos="-0.033  0.033 0.010" material="cf_prop" contype="0" conaffinity="0"/>
      <geom name="cf_prop_bl" type="cylinder" size="0.023 0.001" pos="-0.033 -0.033 0.010" material="cf_prop" contype="0" conaffinity="0"/>

      <!-- Visual-only "halo" marker so the tiny Crazyflie is visible from
           the overview cameras in a 6x6 m room. Non-colliding. -->
      <geom name="cf_halo" type="sphere" size="0.12" pos="0 0 0"
            rgba="1.0 0.4 0.0 0.35" contype="0" conaffinity="0" mass="0"/>
      <geom name="cf_halo_top" type="cylinder" size="0.005 0.15" pos="0 0 0.15"
            rgba="1.0 0.4 0.0 0.9" contype="0" conaffinity="0" mass="0"/>

      <!-- Forward-facing onboard RGB. -->
      <camera name="ego_cam" pos="0.025 0 0.005" xyaxes="0 -1 0  0.10 0 0.995" fovy="70"/>

      <site name="imu"       pos="0 0 0" size="0.002"/>
      <site name="actuation" pos="0 0 0" size="0.002"/>
    </body>

    <!-- Static overview cameras (inside the room; ceiling is rendered in
         group 3, which is culled from these cameras so we can see in). -->
    <camera name="isometric" pos="3.0 -3.0 2.8" xyaxes="0.707 0.707 0 -0.5 0.5 0.707" fovy="75"/>
    <camera name="topdown"   pos="0 0 2.9"     xyaxes="1 0 0 0 1 0" fovy="90"/>
  </worldbody>

  <actuator>
    <motor name="body_thrust" site="actuation" gear="0 0 1 0 0 0"      ctrlrange="0 0.35"/>
    <!-- Moment authority bumped from Menagerie's 1e-5 to 1e-3 (real CF2 has
         ~5e-3 N*m peak roll/pitch authority); makes the attitude inner loop
         actually trackable.  Sign kept negative for Menagerie compatibility. -->
    <motor name="x_moment"    site="actuation" gear="0 0 0 -1e-3 0 0"  ctrlrange="-1 1"/>
    <motor name="y_moment"    site="actuation" gear="0 0 0 0 -1e-3 0"  ctrlrange="-1 1"/>
    <motor name="z_moment"    site="actuation" gear="0 0 0 0 0 -1e-3"  ctrlrange="-1 1"/>
  </actuator>

  <sensor>
    <gyro          name="body_gyro"   site="imu"/>
    <accelerometer name="body_linacc" site="imu"/>
    <framequat     name="body_quat"   objtype="site" objname="imu"/>
  </sensor>
</mujoco>
